<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mashiro.business.mapper.RepaymentPlansMapper">

    <resultMap id="BaseResultMap" type="com.mashiro.business.domain.RepaymentPlans">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="planName" column="plan_name" jdbcType="VARCHAR"/>
            <result property="paymentDay" column="payment_day" jdbcType="TINYINT"/>
            <result property="totalCount" column="total_count" jdbcType="INTEGER"/>
            <result property="amountPerPeriod" column="amount_per_period" jdbcType="DECIMAL"/>
            <result property="totalAmount" column="total_amount" jdbcType="DECIMAL"/>
            <result property="startDate" column="start_date" jdbcType="DATE"/>
            <result property="endDate" column="end_date" jdbcType="DATE"/>
            <result property="status" column="status" jdbcType="TINYINT"/>
            <result property="description" column="description" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,plan_name,payment_day,
        total_count,amount_per_period,total_amount,
        start_date,end_date,status,
        description,create_time,update_time
    </sql>

    <resultMap type="RepaymentPlans" id="RepaymentPlansResult">
        <result property="id"    column="id"    />
        <result property="planName"    column="plan_name"    />
        <result property="paymentDay"    column="payment_day"    />
        <result property="totalCount"    column="total_count"    />
        <result property="amountPerPeriod"    column="amount_per_period"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="startDate"    column="start_date"    />
        <result property="endDate"    column="end_date"    />
        <result property="status"    column="status"    />
        <result property="description"    column="description"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <resultMap id="RepaymentPlansRepaymentRecordsResult" type="RepaymentPlans" extends="RepaymentPlansResult">
        <collection property="repaymentRecordsList" ofType="RepaymentRecords" column="id" select="selectRepaymentRecordsList" />
    </resultMap>

    <resultMap type="RepaymentRecords" id="RepaymentRecordsResult">
        <result property="id"    column="id"    />
        <result property="planId"    column="plan_id"    />
        <result property="repaymentDate"    column="repayment_date"    />
        <result property="amount"    column="amount"    />
        <result property="count"    column="count"    />
        <result property="recordType"    column="record_type"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectRepaymentPlansVo">
        select id, plan_name, payment_day, total_count, amount_per_period, total_amount, start_date, end_date, status, description, create_time, update_time from repayment_plans
    </sql>

    <select id="selectRepaymentPlansList" parameterType="RepaymentPlans" resultMap="RepaymentPlansResult">
        <include refid="selectRepaymentPlansVo"/>
        <where>
            <if test="planName != null  and planName != ''"> and plan_name like concat('%', #{planName}, '%')</if>
            <if test="paymentDay != null "> and payment_day = #{paymentDay}</if>
            <if test="totalCount != null "> and total_count = #{totalCount}</if>
            <if test="amountPerPeriod != null "> and amount_per_period = #{amountPerPeriod}</if>
            <if test="totalAmount != null "> and total_amount = #{totalAmount}</if>
            <if test="startDate != null "> and start_date = #{startDate}</if>
            <if test="endDate != null "> and end_date = #{endDate}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
        </where>
    </select>

    <select id="selectRepaymentPlansById" parameterType="Long" resultMap="RepaymentPlansRepaymentRecordsResult">
        select id, plan_name, payment_day, total_count, amount_per_period, total_amount, start_date, end_date, status, description, create_time, update_time
        from repayment_plans
        where id = #{id}
    </select>

    <select id="selectRepaymentRecordsList" resultMap="RepaymentRecordsResult">
        select id, plan_id, repayment_date, amount, count, record_type, status, remark, create_time, update_time
        from repayment_records
        where plan_id = #{plan_id}
    </select>

    <insert id="insertRepaymentPlans" parameterType="RepaymentPlans" useGeneratedKeys="true" keyProperty="id">
        insert into repayment_plans
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="planName != null and planName != ''">plan_name,</if>
            <if test="paymentDay != null">payment_day,</if>
            <if test="totalCount != null">total_count,</if>
            <if test="amountPerPeriod != null">amount_per_period,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="startDate != null">start_date,</if>
            <if test="endDate != null">end_date,</if>
            <if test="status != null">status,</if>
            <if test="description != null">description,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="planName != null and planName != ''">#{planName},</if>
            <if test="paymentDay != null">#{paymentDay},</if>
            <if test="totalCount != null">#{totalCount},</if>
            <if test="amountPerPeriod != null">#{amountPerPeriod},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="status != null">#{status},</if>
            <if test="description != null">#{description},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateRepaymentPlans" parameterType="RepaymentPlans">
        update repayment_plans
        <trim prefix="SET" suffixOverrides=",">
            <if test="planName != null and planName != ''">plan_name = #{planName},</if>
            <if test="paymentDay != null">payment_day = #{paymentDay},</if>
            <if test="totalCount != null">total_count = #{totalCount},</if>
            <if test="amountPerPeriod != null">amount_per_period = #{amountPerPeriod},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="status != null">status = #{status},</if>
            <if test="description != null">description = #{description},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteRepaymentPlansById" parameterType="Long">
        delete from repayment_plans where id = #{id}
    </delete>

    <delete id="deleteRepaymentPlansByIds" parameterType="Long">
        delete from repayment_plans where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteRepaymentRecordsByPlanIds" parameterType="Long">
        delete from repayment_records where plan_id in
        <foreach item="planId" collection="array" open="(" separator="," close=")">
            #{planId}
        </foreach>
    </delete>

    <delete id="deleteRepaymentRecordsByPlanId" parameterType="Long">
        delete from repayment_records where plan_id = #{planId}
    </delete>

    <insert id="batchRepaymentRecords">
        insert into repayment_records( id, plan_id, repayment_date, amount, count, record_type, status, remark, create_time, update_time) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.planId}, #{item.repaymentDate}, #{item.amount}, #{item.count}, #{item.recordType}, #{item.status}, #{item.remark}, #{item.createTime}, #{item.updateTime})
        </foreach>
    </insert>

    <!-- ==================== 前端日历页面专用SQL ==================== -->

    <!-- 查询所有还款记录用于日历显示 -->
    <select id="selectAllRepaymentRecords" resultMap="RepaymentRecordsResult">
        select id, plan_id, repayment_date, amount, count, record_type, status, remark, create_time, update_time
        from repayment_records
        where status = 1
        order by repayment_date asc
    </select>

    <!-- 新增单笔还款记录 -->
    <insert id="insertRepaymentRecord" parameterType="RepaymentRecords" useGeneratedKeys="true" keyProperty="id">
        insert into repayment_records
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="planId != null">plan_id,</if>
            <if test="repaymentDate != null">repayment_date,</if>
            <if test="amount != null">amount,</if>
            <if test="count != null">count,</if>
            <if test="recordType != null">record_type,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="planId != null">#{planId},</if>
            <if test="repaymentDate != null">#{repaymentDate},</if>
            <if test="amount != null">#{amount},</if>
            <if test="count != null">#{count},</if>
            <if test="recordType != null">#{recordType},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <!-- 批量新增或更新还款记录 -->
    <insert id="batchInsertOrUpdateRepaymentRecords">
        insert into repayment_records(plan_id, repayment_date, amount, count, record_type, status, remark, create_time, update_time) values
        <foreach item="item" index="index" collection="list" separator=",">
            (#{item.planId}, #{item.repaymentDate}, #{item.amount}, #{item.count}, #{item.recordType}, #{item.status}, #{item.remark}, #{item.createTime}, #{item.updateTime})
        </foreach>
        ON DUPLICATE KEY UPDATE
        amount = VALUES(amount),
        count = VALUES(count),
        update_time = VALUES(update_time)
    </insert>

    <!-- 根据日期和金额删除还款记录 -->
    <delete id="deleteRepaymentRecordByDateAndAmount">
        delete from repayment_records
        where DATE(repayment_date) = #{repaymentDate}
          and amount = #{amount}
    </delete>

    <!-- 获取还款统计数据 -->
    <select id="getRepaymentStatistics" resultType="java.util.Map">
        select
            COALESCE(COUNT(*), 0) as totalRecords,
            COALESCE(SUM(amount), 0) as totalAmount,
            COALESCE(SUM(count), 0) as totalCount,
            MIN(repayment_date) as firstRepaymentDate,
            MAX(repayment_date) as lastRepaymentDate
        from repayment_records
        where status = 1
    </select>

    <!-- 获取月度汇总数据 -->
    <select id="getMonthlyTotals" resultType="java.util.Map">
        select
            DATE_FORMAT(repayment_date, '%Y-%m') as month,
            SUM(amount) as totalAmount,
            SUM(count) as totalCount,
            COUNT(*) as recordCount
        from repayment_records
        where status = 1
        group by DATE_FORMAT(repayment_date, '%Y-%m')
        order by month
    </select>

    <!-- 根据日期和金额查询还款记录 -->
    <select id="selectRepaymentRecordByDateAndAmount" resultMap="RepaymentRecordsResult">
        select id, plan_id, repayment_date, amount, count, record_type, status, remark, create_time, update_time
        from repayment_records
        where DATE(repayment_date) = #{repaymentDate}
          and amount = #{amount}
          and status = 1
            limit 1
    </select>
    <select id="getStartAndEndDate" resultType="com.mashiro.business.domain.RepaymentPlans">
        select  MIN(start_date) as startDate, MAX(end_date) as endDate
        from repayment_plans
        where status = 1
    </select>

    <!-- 清空所有还款记录 -->
    <delete id="deleteAllRepaymentRecords">
        delete from repayment_records
    </delete>
</mapper>
